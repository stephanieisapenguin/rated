# Frontend (Vite) environment variables.
# Copy to .env.local for local dev. Vite only exposes vars prefixed with VITE_.
# In production, set these in Netlify → Site settings → Environment variables.

# Backend API base URL.
# Local dev:  http://localhost:8000
# Production: https://<your-backend-host>   (Render / Railway / Fly / Replit)
VITE_API_BASE_URL=http://localhost:8000

# Note: there is no longer a VITE_TMDB_API_KEY — TMDB calls now go through
# the backend's /tmdb/* proxy so the key stays server-side. Set TMDB_API_KEY
# on the backend instead (see backend/.env.example).
